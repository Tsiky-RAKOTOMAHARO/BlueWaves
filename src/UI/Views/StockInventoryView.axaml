<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Core.Models;assembly=Core"
             x:Class="UI.Views.StockInventoryView"
             x:CompileBindings="False"
             Background="#F8FAFC">

    <UserControl.Styles>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="Border.kpi">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>

        <Style Selector="Border.contact-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Border.contact-card:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <Style Selector="TextBox.form-input">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-primary-green">
            <Setter Property="Background" Value="#10B981"/>
        </Style>

        <Style Selector="Button.btn-icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="20">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Gestion des Stocks"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#1E293B"/>

                <TextBlock Text="État des entrepôts et produits associés"
                           FontSize="13"
                           Foreground="#94A3B8"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Click="OuvrirPanneau_Click"
                    Classes="btn-primary btn-primary-green">
                <TextBlock Text="+ Nouveau Stock"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

            <DockPanel Grid.Column="0">

                <!-- KPI -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,16,*" Margin="0,0,0,24">

                    <Border Classes="kpi">
                        <StackPanel>
                            <TextBlock Text="TOTAL STOCKS" Classes="label"/>
                            <TextBlock Text="{Binding Stocks.Count}"
                                       FontSize="28"
                                       FontWeight="Black"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Classes="kpi">
                        <StackPanel>
                            <TextBlock Text="PRODUITS DU STOCK" Classes="label"/>
                            <TextBlock Text="{Binding ProduitsduStock.Count}"
                                       FontSize="28"
                                       FontWeight="Black"
                                       Foreground="#10B981"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- LISTE STOCKS -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Stocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:Stock">

                                <Border Classes="contact-card"
                                        PointerPressed="OnStockSelected_Click">

                                    <Grid ColumnDefinitions="2,*,*">

                                        <Border Grid.Column="0" Background="#10B981"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="N° STOCK" Classes="label"/>
                                            <TextBlock Text="{Binding NumeroStock, StringFormat='S-{0}'}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding NomStock}"
                                                       FontWeight="Bold"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>

            <!-- FORMULAIRE -->
            <Border Grid.Column="1"
                    x:Name="PanneauLateral"
                    IsVisible="{Binding IsFormVisible}"
                    Width="320"
                    Margin="16,0,0,0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24">

                <StackPanel Spacing="15">

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseForm}"
                                Content="✕"
                                Classes="btn-icon"/>
                         <TextBlock Text="Nouveau Stock"
                                   FontSize="18" FontWeight="Bold" Foreground="Blue"/>
                    </DockPanel>

                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>

                     <StackPanel Spacing="5">
                        <TextBlock Text="Désignation du stock" Classes="label"/>
                        <TextBox Classes="form-input"
                                 Watermark="ex: Entrepôt Nord, Chambre Froide..."
                                 Text="{Binding NomStock, Mode=TwoWay}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="*,10,*" Margin="0,10,0,0">
                        <Button Grid.Column="0"
                                Command="{Binding CloseForm}"
                                Content="Annuler"
                                Background="#F1F5F9"
                                Foreground="#64748B"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,10"/>
                        <Button Grid.Column="2"
                                Click="SaveStock_Click"
                                Classes="btn-primary btn-primary-green"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,10">
                            <TextBlock Text="Enregistrer" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- DETAIL -->
            <Border Grid.Column="1"
                    x:Name="PanneauDetail"
                    IsVisible="{Binding IsDetailVisible}"
                    Width="320"
                    Margin="16,0,0,0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24">

                <StackPanel Spacing="15">

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseDetail}"
                                Content="✕"
                                Classes="btn-icon"/>

                        <TextBlock Text="Produits du stock"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                    </DockPanel>

                    <TextBlock Text="{Binding SelectedStock.NomStock, TargetNullValue=''}"
                               FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#10B981"/>
                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ProduitsduStock}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:StockProduit">
                                    <Border Background="#F8FAFC"
                                            CornerRadius="8"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="12,10"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Produit.NomProduit}"
                                                           FontWeight="SemiBold" FontSize="13" Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding Quantite, StringFormat='{}Qté : {0}'}"
                                                           FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#F0FDF4" CornerRadius="4"
                                                    Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CodeProduit, StringFormat='{}P-{0}'}"
                                                           FontSize="11" FontWeight="Bold" Foreground="#16A34A"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="Aucun produit"
                               IsVisible="{Binding AucunProduit}"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>