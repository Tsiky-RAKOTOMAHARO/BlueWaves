<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.Views.StockInventoryView">
    <StackPanel Margin="20">
        <TextBlock Text="Inventaire du Stock" FontSize="20" FontWeight="Bold"/>
        <Separator Margin="0,10"/>
        <TextBlock Text="Visualisation des produits en entrepôt."/>
    </StackPanel>
</UserControl>