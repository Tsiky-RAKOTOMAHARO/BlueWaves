<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:coreModels="clr-namespace:Core.Models;assembly=Core"
             x:Class="UI.Views.PurchaseOrderView"
             x:CompileBindings="False"
             Tag="Achats &amp; Appro"
             Background="#F8FAFC">

    <UserControl.Styles>

        <Style Selector="TabItem">
            <Setter Property="FontSize"     Value="15"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="Foreground"   Value="#64748B"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground"   Value="#1E293B"/>
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Foreground"   Value="#64748B"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <Style Selector="TextBlock.form-section">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#94A3B8"/>
            <Setter Property="Margin"       Value="0,15,0,10"/>
        </Style>

        <Style Selector="Border.order-card">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="20,16"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition              Property="Background"    Duration="0:0:0.15"/>
                    <BrushTransition              Property="BorderBrush"   Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.order-card:pointerover">
            <Setter Property="Background"       Value="#F1F5F9"/>
            <Setter Property="BorderBrush"      Value="#CBD5E1"/>
            <Setter Property="RenderTransform"  Value="scale(1.01)"/>
        </Style>

      
        <Style Selector="Border.kpi">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="20,16"/>
        </Style>

        <Style Selector="TextBox.form-input, ComboBox.form-input, NumericUpDown.form-input, DatePicker.form-input">
            <Setter Property="Background"       Value="#F8FAFC"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-primary-green">
            <Setter Property="Background"   Value="#10B981"/>
        </Style>
        <Style Selector="Button.btn-primary-blue">
            <Setter Property="Background"   Value="#3B82F6"/>
        </Style>

        <!-- FIX: btn-icon style was used but never defined -->
        <Style Selector="Button.btn-icon">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="FontSize"         Value="18"/>
            <Setter Property="Foreground"       Value="#94A3B8"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-icon:pointerover">
            <Setter Property="Foreground"       Value="#1E293B"/>
        </Style>

  
        <Style Selector="Border.search-shell">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
        </Style>

    </UserControl.Styles>


    <Grid RowDefinitions="Auto,*" Margin="20">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Gestion Commerciale"
                           FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Suivi des flux d'approvisionnement et export"
                           FontSize="13" Foreground="#94A3B8"/>
            </StackPanel>
        </Grid>

        <!-- Tab control -->
        <TabControl Grid.Row="1" Background="Transparent" Margin="0,-8,0,0">

            <TabItem Header="Approvisionnement">
                <Grid RowDefinitions="Auto,*">

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,20">
                        <Border Grid.Column="0" Classes="search-shell" Width="350" HorizontalAlignment="Left">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon Grid.Column="0"
                                          Data="{StaticResource SearchIcon}"
                                          Width="14" Margin="12,0" Foreground="#94A3B8"/>
                                <TextBox Grid.Column="1"
                                         x:Name="SearchAppro"
                                         Watermark="Rechercher un certificat..."
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         TextChanged="OnApproSearchChanged"/>
                            </Grid>
                        </Border>
                        <!-- Spacer -->
                        <Border Grid.Column="1" Background="Transparent"/>
                        <Button Grid.Column="2"
                                Content="＋ Nouvelle réception"
                                Classes="btn-primary btn-primary-green"
                                Click="OnNouvelleReceptionClick"/>
                    </Grid>

                    <!-- Content: list + slide-in form -->
                    <!-- FIX: removed spurious Grid.Row="1" from form panel;
                         parent grid has no RowDefinitions, only ColumnDefinitions -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                        <!-- Left: KPI + list -->
                        <DockPanel Grid.Column="0">

                            <!-- KPI row -->
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,*,*" ColumnSpacing="16"
                                  Margin="0,0,0,24">
                                <Border Grid.Column="0" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="RÉCEPTIONS (MOIS)" Classes="label"/>
                                        <TextBlock x:Name="KpiReceptions"
                                                   Text="24"
                                                   FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="VALEUR TOTALE" Classes="label"/>
                                        <TextBlock x:Name="KpiValeur"
                                                   Text="12 450 000"
                                                   FontSize="28" FontWeight="Black" Foreground="#10B981"/>
                                        <TextBlock Text="Ariary MGA" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="FOURNISSEURS" Classes="label"/>
                                        <TextBlock x:Name="KpiFournisseurs"
                                                   Text="12"
                                                   FontSize="28" FontWeight="Black" Foreground="#3B82F6"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- List -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl x:Name="ApproList"
                                                  ItemsSource="{Binding ApprovisionnementVM.FilteredApprovisionnements}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="coreModels:Approvisionnement">
                                                <Border Classes="order-card" PointerPressed="OnApproCardClick">
                                                    <Grid ColumnDefinitions="4,*,130,130,Auto">

                                                        <!-- Color accent -->
                                                        <Border Grid.Column="0"
                                                                Background="#10B981" CornerRadius="2"/>

                                                        <!-- Fournisseur -->
                                                        <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Fournisseur.NomFournisseur}"
                                                                       FontWeight="Bold" FontSize="14"/>
                                                            <!-- FIX: #{0} → use {}{0} prefix to avoid XAML parser ambiguity -->
                                                            <TextBlock Text="{Binding RefFournisseur, StringFormat='{}Fournisseur #{0}'}"
                                                                       FontSize="12" Foreground="#64748B"/>
                                                        </StackPanel>

                                                        <!-- Référence -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="Référence" Classes="label"/>
                                                            <TextBlock Text="{Binding Certificat}" FontSize="13"/>
                                                        </StackPanel>

                                                        <!-- Date + Produit -->
                                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                            <TextBlock Text="Date réception" Classes="label"/>
                                                            <TextBlock Text="{Binding Produit.Date_reception, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                                       FontSize="13"/>
                                                            <TextBlock Text="{Binding Produit.NomProduit}"
                                                                       FontSize="12" Foreground="#64748B"/>
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <Button Grid.Column="4"
                                                                Classes="btn-icon"
                                                                Content="⋮"
                                                                Margin="15,0,0,0"
                                                                Click="OnApproActionsClick"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <Border x:Name="ApproEmptyState"
                                            IsVisible="False"
                                            Padding="40"
                                            HorizontalAlignment="Center">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <TextBlock Text="Aucune réception trouvée"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Modifiez votre recherche ou créez une nouvelle réception."
                                                       FontSize="13" Foreground="#94A3B8"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- Right: slide-in form panel -->
                        <!-- FIX: Grid.Row="1" removed — parent has no row definitions -->
                        <Border Grid.Column="1"
                                x:Name="ApproFormPanel"
                                IsVisible="False"
                                Width="380"
                                Margin="16,0,0,0"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24">
                            <ScrollViewer>
                                <StackPanel Spacing="15">

                                    <!-- Form header -->
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Classes="btn-icon"
                                                Click="OnApproFormClose"/>
                                        <!-- x:Name added so code-behind can update title for new vs edit -->
                                        <TextBlock x:Name="ApproFormTitle"
                                                   Text="Détails Réception"
                                                   FontSize="18" FontWeight="Bold"/>
                                    </DockPanel>

                                    <!-- FIX: Separator doesn't support Background in Avalonia; use Border -->
                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>

                                    <TextBlock Text="INFORMATIONS GÉNÉRALES" Classes="form-section"/>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Certificat" Classes="label"/>
                                        <TextBox x:Name="ApproCertificat"
                                                 Classes="form-input"
                                                 Watermark="Référence certificat"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Référence fournisseur" Classes="label"/>
                                        <ComboBox x:Name="ApproRefFournisseurCombo"
                                                  Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  DisplayMemberBinding="{Binding NomFournisseur}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Code produit" Classes="label"/>
                                        <ComboBox x:Name="ApproCodeProduitCombo"
                                                  Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  DisplayMemberBinding="{Binding NomProduit}"/>
                                    </StackPanel>

                                    <!-- Error message -->
                                    <TextBlock x:Name="ApproErrorText"
                                               Foreground="#DC2626"
                                               IsVisible="False"
                                               TextWrapping="Wrap"/>

                                    <Button Content="Enregistrer la réception"
                                            Classes="btn-primary btn-primary-green"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,20,0,0"
                                            Click="OnApproSave"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </TabItem>

      
            <TabItem Header="Commandes Export">
                <Grid RowDefinitions="Auto,*">

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,20">
                        <Border Grid.Column="0" Classes="search-shell" Width="350" HorizontalAlignment="Left">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon Grid.Column="0"
                                          Data="{StaticResource SearchIcon}"
                                          Width="14" Margin="12,0" Foreground="#94A3B8"/>
                                <TextBox Grid.Column="1"
                                         x:Name="SearchCommande"
                                         Watermark="Rechercher destination ou N°..."
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         TextChanged="OnCommandeSearchChanged"/>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Background="Transparent"/>
                        <Button Grid.Column="2"
                                Content="＋ Nouvelle commande"
                                Classes="btn-primary btn-primary-blue"
                                Click="OnNouvelleCommandeClick"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                        <DockPanel Grid.Column="0">

                            <!-- KPI row -->
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,*,*" ColumnSpacing="16"
                                  Margin="0,0,0,24">
                                <Border Grid.Column="0" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="COMMANDES (MOIS)" Classes="label"/>
                                        <TextBlock x:Name="KpiCommandes"
                                                   Text="—"
                                                   FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="DESTINATIONS" Classes="label"/>
                                        <TextBlock x:Name="KpiDestinations"
                                                   Text="—"
                                                   FontSize="28" FontWeight="Black" Foreground="#3B82F6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="CLIENTS" Classes="label"/>
                                        <TextBlock x:Name="KpiClients"
                                                   Text="—"
                                                   FontSize="28" FontWeight="Black" Foreground="#F59E0B"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- List -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl x:Name="CommandeList"
                                                  ItemsSource="{Binding CommandeVM.FilteredCommandes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="coreModels:Commande">
                                                <Border Classes="order-card" PointerPressed="OnCommandeCardClick">
                                                    <Grid ColumnDefinitions="4,*,150,130,120,Auto">

                                                        <!-- Color accent -->
                                                        <Border Grid.Column="0"
                                                                Background="#3B82F6" CornerRadius="2"/>

                                                        <!-- Destination -->
                                                        <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Destination}"
                                                                       FontWeight="Bold" FontSize="14"/>
                                                            <TextBlock Text="{Binding NumeroCommande, StringFormat='{}Commande #{0}'}"
                                                                       FontSize="12" Foreground="#64748B"/>
                                                        </StackPanel>

                                                        <!-- Date -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="Date" Classes="label"/>
                                                            <TextBlock Text="{Binding DateCommande, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                                       FontSize="13"/>
                                                        </StackPanel>

                                                        <!-- Réf. Client -->
                                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                            <TextBlock Text="Réf. Client" Classes="label"/>
                                                            <TextBlock Text="{Binding RefClient}" FontSize="13"/>
                                                        </StackPanel>

                                                        <!-- N° Export -->
                                                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                            <TextBlock Text="N° Export" Classes="label"/>
                                                            <TextBlock Text="{Binding CodeExport}" FontSize="13"/>
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <Button Grid.Column="5"
                                                                Classes="btn-icon"
                                                                Content="⋮"
                                                                Margin="15,0,0,0"
                                                                Click="OnCommandeActionsClick"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <Border x:Name="CommandeEmptyState"
                                            IsVisible="False"
                                            Padding="40"
                                            HorizontalAlignment="Center">
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <TextBlock Text="Aucune commande trouvée"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="#64748B"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Modifiez votre recherche ou créez une nouvelle commande."
                                                       FontSize="13" Foreground="#94A3B8"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>

                        <Border Grid.Column="1"
                                x:Name="CommandeFormPanel"
                                IsVisible="False"
                                Width="380"
                                Margin="16,0,0,0"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24">
                            <ScrollViewer>
                                <StackPanel Spacing="15">

                                    <!-- Form header -->
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Classes="btn-icon"
                                                Click="OnCommandeFormClose"/>
                                        <!-- x:Name added so code-behind can toggle "Nouvelle" / "Détails" -->
                                        <TextBlock x:Name="CommandeFormTitle"
                                                   Text="Nouvelle Commande"
                                                   FontSize="18" FontWeight="Bold"/>
                                    </DockPanel>

                                    <!-- FIX: Border instead of Separator for reliable Background -->
                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Destination" Classes="label"/>
                                        <TextBox x:Name="CommandeDestination"
                                                 Classes="form-input"
                                                 Watermark="Pays / Port de destination"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Date commande" Classes="label"/>
                                        <DatePicker x:Name="CommandeDate" Classes="form-input"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Référence client" Classes="label"/>
                                        <ComboBox x:Name="CommandeRefClientCombo"
                                                  Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  DisplayMemberBinding="{Binding NomClient}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Numéro export" Classes="label"/>
                                        <TextBlock Text="Généré automatiquement lors de l'enregistrement"
                                                   FontSize="12" Foreground="#94A3B8"/>
                                    </StackPanel>

                                    <!-- Error message -->
                                    <TextBlock x:Name="CommandeErrorText"
                                               Foreground="#DC2626"
                                               IsVisible="False"
                                               TextWrapping="Wrap"/>

                                    <Button Content="Enregistrer la commande"
                                            Classes="btn-primary btn-primary-blue"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,20,0,0"
                                            Click="OnCommandeSave"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
