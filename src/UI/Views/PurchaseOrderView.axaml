<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:coreModels="clr-namespace:Core.Models;assembly=Core"
             x:Class="UI.Views.PurchaseOrderView"
             xmlns:vm="clr-namespace:UI.ViewModels"
             x:CompileBindings="False"
             Tag="Achats &amp; Appro"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*" Margin="20">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Gestion Commerciale"
                           FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Suivi des flux d'approvisionnement et export"
                           FontSize="13" Foreground="#94A3B8"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" Margin="0,-8,0,0">

            <!-- ═══════════════════════════════════════════════════ APPRO -->
            <TabItem Header="Approvisionnement">
                <Grid RowDefinitions="Auto,*">

                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
                        <Border Grid.Column="0" Classes="search-shell" Width="350" HorizontalAlignment="Left">
                            <TextBox Watermark="Rechercher un Fournisseur..."
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding ApproVM.SearchQuery, Mode=TwoWay}"/>
                        </Border>
                        <Border Grid.Column="1" Background="Transparent"/>
                        <Button Grid.Column="2"
                                Content="＋ Nouvelle réception"
                                Classes="btn-primary btn-primary-green"
                                Command="{Binding ApproVM.NouvelleReceptionCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                        <DockPanel Grid.Column="0">

                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" Margin="0,0,0,24">
                                <Border Grid.Column="0" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL RÉCEPTIONS" Classes="label"/>
                                        <TextBlock Text="{Binding ApproVM.Approvisionnements.Count}"
                                                   FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="FOURNISSEURS" Classes="label"/>
                                        <TextBlock Text="{Binding ApproVM.Fournisseurs.Count}"
                                                   FontSize="28" FontWeight="Black" Foreground="#3B82F6"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ApproVM.FilteredApprovisionnements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="coreModels:Approvisionnement">
                                            <Border Classes="order-card" PointerPressed="OnApproCardClick">
                                                <Grid ColumnDefinitions="4,*,*,*,*,Auto">
                                                    <Border Grid.Column="0" Background="#10B981" CornerRadius="2"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="CERTIFICAT" Classes="label"/>
                                                        <TextBlock Text="{Binding Certificat}"
                                                                   FontSize="13" Foreground="#16A34A" FontWeight="Bold"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="16,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Fournisseur.NomFournisseur}"
                                                                   FontWeight="Bold" FontSize="14" Foreground="#0F172A"/>
                                                        <TextBlock Text="{Binding RefFournisseur, StringFormat='{}F-{0}'}"
                                                                   FontSize="12" Foreground="#64748B"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Margin="16,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Produit.NomProduit}"
                                                                   FontWeight="Bold" FontSize="14" Foreground="#0F172A"/>
                                                        <TextBlock Text="{Binding Quantite, StringFormat='{}{0}kg'}"
                                                                   FontSize="12" Foreground="#64748B"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                        <TextBlock Text="DATE RÉCEPTION" Classes="label"/>
                                                        <TextBlock Text="{Binding DateReception, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                                   FontSize="13" Foreground="#64748B"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="5"
                                                            Classes="btn-icon"
                                                            Content="⋮"
                                                            Click="OnApproActionsClick">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Supprimer" Click="OnDeleteApproClick"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <Border Grid.Column="1"
                                IsVisible="{Binding ApproVM.IsFormVisible}"
                                Width="380"
                                Margin="16,0,0,0"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24">
                            <ScrollViewer>
                                <StackPanel Spacing="15">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Classes="btn-icon"
                                                Command="{Binding ApproVM.FermerFormulaireCommand}"/>
                                        <TextBlock Text="Nouvelle Réception"
                                                   FontSize="18" FontWeight="Bold" Foreground="Blue"/>
                                    </DockPanel>
                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>
                                    <TextBlock Text="INFORMATIONS GÉNÉRALES" Classes="form-section"/>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Certificat" Classes="label"/>
                                        <TextBox Classes="form-input"
                                                 Watermark="Référence certificat"
                                                 Text="{Binding ApproVM.CertificatSaisi, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Fournisseur" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ApproVM.Fournisseurs}"
                                                  SelectedItem="{Binding ApproVM.SelectedFournisseur, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomFournisseur}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Produit" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ApproVM.Produits}"
                                                  SelectedItem="{Binding ApproVM.SelectedProduit, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomProduit}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Stock" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ApproVM.Stocks}"
                                                  SelectedItem="{Binding ApproVM.SelectedStock, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomStock}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Quantité" Classes="label"/>
                                        <TextBox Classes="form-input"
                                                 Watermark="Ex: 100"
                                                 Text="{Binding ApproVM.QuantiteSaisie, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ApproVM.ErrorMessage}"
                                               Foreground="#DC2626"
                                               IsVisible="{Binding ApproVM.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               TextWrapping="Wrap"/>
                                    <Button Content="Enregistrer la réception"
                                            Classes="btn-primary btn-primary-green"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,10,0,0"
                                            Command="{Binding ApproVM.SauvegarderCommand}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════ COMMANDE -->
            <TabItem Header="Commandes Export">
                <Grid RowDefinitions="Auto,*">

                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
                        <Border Grid.Column="0" Classes="search-shell" Width="350" HorizontalAlignment="Left">
                            <TextBox Watermark="Rechercher destination ou N°..."
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding CommandeVM.SearchQuery, Mode=TwoWay}"/>
                        </Border>
                        <Border Grid.Column="1" Background="Transparent"/>
                        <Button Grid.Column="2"
                                Content="＋ Nouvelle commande"
                                Classes="btn-primary btn-primary-green"
                                Command="{Binding CommandeVM.NouvelleCommandeCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                        <DockPanel Grid.Column="0">

                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*,*" Margin="0,0,0,24">
                                <Border Grid.Column="0" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL COMMANDES" Classes="label"/>
                                        <TextBlock Text="{Binding CommandeVM.Commandes.Count}"
                                                   FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="kpi" Margin="12,0">
                                    <StackPanel>
                                        <TextBlock Text="CLIENTS" Classes="label"/>
                                        <TextBlock Text="{Binding CommandeVM.Clients.Count}"
                                                   FontSize="28" FontWeight="Black" Foreground="#3B82F6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="kpi">
                                    <StackPanel>
                                        <TextBlock Text="STATUT EXPORT" Classes="label"/>
                                        <TextBlock Text="EN COURS"
                                                   FontSize="20" FontWeight="Bold" Foreground="#F59E0B" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CommandeVM.FilteredCommandes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="coreModels:Commande">
                                            <Border Classes="order-card" PointerPressed="OnCommandeCardClick">
                                                <Grid ColumnDefinitions="4,*,*,*,*,Auto">
                                                    <Border Grid.Column="0" Background="#3B82F6" CornerRadius="2"/>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="DESTINATION" Classes="label"/>
                                                        <TextBlock Text="{Binding Destination}"
                                                                   FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="CLIENT" Classes="label"/>
                                                        <TextBlock Text="{Binding Client.NomClient}"
                                                                   FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                        <TextBlock Text="DÉLAI (j)" Classes="label"/>
                                                        <TextBlock Text="{Binding Delai}"
                                                                   FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                        <TextBlock Text="DATE" Classes="label"/>
                                                        <TextBlock Text="{Binding DateCommande, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                                   FontSize="13" Foreground="#64748B"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="5"
                                                            Classes="btn-icon"
                                                            Content="⋮"
                                                            Click="OnCommandeActionsClick">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Modifier"  Click="OnUpdateCommandeClick"/>
                                                                <MenuItem Header="Supprimer" Click="OnCommandeDeleteClick"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <Border Grid.Column="1"
                                IsVisible="{Binding CommandeVM.IsFormVisible}"
                                Width="420"
                                Margin="16,0,0,0"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24">
                            <ScrollViewer>
                                <StackPanel Spacing="15">

                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="✕"
                                                Classes="btn-icon"
                                                Command="{Binding CommandeVM.FermerFormulaireCommand}"/>
                                        <TextBlock Text="Nouvelle Commande"
                                                   FontSize="18" FontWeight="Bold" Foreground="#3B82F6"/>
                                    </DockPanel>

                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>
                                    <TextBlock Text="DÉTAILS DE L'EXPÉDITION" Classes="form-section"/>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Destination" Classes="label"/>
                                        <TextBox Classes="form-input"
                                                 Watermark="Pays ou Ville de destination"
                                                 Text="{Binding CommandeVM.Destination, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Date de Commande" Classes="label"/>
                                        <DatePicker Classes="form-input"
                                                    HorizontalAlignment="Stretch"
                                                    SelectedDate="{Binding CommandeVM.DateCommande, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Délai (jours)" Classes="label"/>
                                        <TextBox Classes="form-input"
                                                 Watermark="Ex: 30"
                                                 Text="{Binding CommandeVM.Delai, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Client" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CommandeVM.Clients}"
                                                  SelectedItem="{Binding CommandeVM.SelectedClient, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomClient}"/>
                                    </StackPanel>

                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>
                                    <TextBlock Text="PRODUITS COMMANDÉS" Classes="form-section"/>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Produit" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CommandeVM.Produits}"
                                                  SelectedItem="{Binding CommandeVM.SelectedProduit, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomProduit}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Stock" Classes="label"/>
                                        <ComboBox Classes="form-input"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CommandeVM.Stocks}"
                                                  SelectedItem="{Binding CommandeVM.SelectedStock, Mode=TwoWay}"
                                                  DisplayMemberBinding="{Binding NomStock}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Quantité" Classes="label"/>
                                        <TextBox Classes="form-input"
                                                 Watermark="0"
                                                 Text="{Binding CommandeVM.Quantite, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <Button Content="＋ Ajouter la ligne"
                                            Classes="btn-primary"
                                            Foreground="Green"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding CommandeVM.AjouterLigneCommand}"/>

                                    <Border Height="1" Background="#F1F5F9" Margin="0,5"/>
                                    <TextBlock Text="LIGNES DE COMMANDE" Classes="form-section"/>

                                    <ItemsControl ItemsSource="{Binding CommandeVM.Lignes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10,8"
                                                        Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock Text="{Binding CodeProduit, StringFormat='Produit #{0}'}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#0F172A"/>
                                                            <TextBlock Text="{Binding NumeroStock, StringFormat='Stock #{0}'}"
                                                                       FontSize="11" Foreground="#64748B"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1"
                                                                Background="#DBEAFE"
                                                                CornerRadius="12"
                                                                Padding="8,3"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0">
                                                            <TextBlock Text="{Binding Quantite, StringFormat='Qté : {0}'}"
                                                                       FontSize="12" FontWeight="Bold"
                                                                       Foreground="#3B82F6"/>
                                                        </Border>
                                                        <Button Grid.Column="2"
                                                                Content="✕"
                                                                Classes="btn-icon"
                                                                Foreground="#DC2626"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding $parent[ItemsControl].DataContext.CommandeVM.RetirerLigneCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{Binding CommandeVM.ErrorMessage}"
                                               Foreground="#DC2626"
                                               FontSize="12"
                                               IsVisible="{Binding CommandeVM.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               TextWrapping="Wrap"/>

                                    <Button Content="Confirmer la commande"
                                            Classes="btn-primary btn-primary-green"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,10,0,0"
                                            Command="{Binding CommandeVM.ConfirmerCommandeCommand}"/>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>

    <UserControl.Styles>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.form-section">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="Border.order-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.order-card:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style Selector="Border.kpi">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style Selector="TextBox.form-input, ComboBox.form-input, DatePicker.form-input">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-primary-green">
            <Setter Property="Background" Value="#10B981"/>
        </Style>
        <Style Selector="Button.btn-icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-icon:pointerover">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        <Style Selector="Border.search-shell">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </UserControl.Styles>

</UserControl>
