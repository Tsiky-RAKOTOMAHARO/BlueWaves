<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.Views.ExportListView"
             Tag="Gestion des Produits"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto, *" Margin="20">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Catalogue des Produits" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Inventaire des marchandises et références SKU" Foreground="#64748B" FontSize="13"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Width="250">
                    <Grid ColumnDefinitions="Auto, *">
                        <PathIcon Data="{StaticResource SearchIcon}" Width="14" Margin="12,0" Foreground="#94A3B8"/>
                        <TextBox Grid.Column="1" Watermark="Rechercher un article..." BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <Button Content="+ Ajouter un produit" 
                        Background="#10B981" Foreground="White" 
                        Padding="20,10" CornerRadius="6" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#059669"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 4 20 0 #08000000" ClipToBounds="True">
            <DataGrid Name="ProductGrid" CanUserResizeColumns="True" GridLinesVisibility="Horizontal" IsReadOnly="True">
                
                <DataGrid.Styles>
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="Padding" Value="15,0"/>
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="SKU" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="BW-CRV-01" VerticalAlignment="Center" Margin="15,0" Foreground="#64748B" FontSize="12"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Désignation" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="Crevettes Tigrées (Surgelées)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#1E293B"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Catégorie" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="Crustacés" VerticalAlignment="Center" Foreground="#64748B"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Stock Actuel" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                                    <TextBlock Text="1,250" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="Kg" Foreground="#94A3B8" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Prix Unit." Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="14.50 €" VerticalAlignment="Center" Foreground="#1E293B"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Statut" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="10,5" Padding="8,4" CornerRadius="4" Background="#DCFCE7" HorizontalAlignment="Left">
                                    <TextBlock Text="En Stock" Foreground="#166534" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>