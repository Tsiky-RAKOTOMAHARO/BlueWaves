<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UI.ViewModels"
             xmlns:m="clr-namespace:Core.Models;assembly=Core"
             x:Class="UI.Views.DirectoryView"
             x:CompileBindings="False"
             Tag="Annuaire"
             Background="#F8FAFC">

    <UserControl.Styles>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style Selector="Border.Card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.Card:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *" Margin="20">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Annuaire des Contacts" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Gestion centralisée des partenaires BlueWaves" FontSize="13" Foreground="#94A3B8"/>
            </StackPanel>

            <Button Grid.Column="1" Background="#10B981" Foreground="White" Padding="20,10" CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource ContactIcon}" Width="14" Height="14"/>
                    <TextBlock Text="Ajouter un contact" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
                
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <Border Width="320" Margin="0" Padding="5" Background="White" CornerRadius="8">
                            <StackPanel Spacing="15">
                                <TextBlock Text="Nouveau Contact" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                                
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Type" Classes="label"/>
                                    <ComboBox x:Name="TypeComboBox" HorizontalAlignment="Stretch" SelectedIndex="0">
                                        <ComboBoxItem>Client</ComboBoxItem>
                                        <ComboBoxItem>Fournisseur</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Nom / Raison Sociale" Classes="label"/>
                                    <TextBox x:Name="NomTextBox" Watermark="ex: Seafood Global Inc."/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Prenoms / Raison Sociale" Classes="label"/>
                                    <TextBox x:Name="PrenomTextBox" Watermark="ex: Rabe"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Telephone " Classes="label"/>
                                    <TextBox x:Name="TelephoneTextBox" Watermark="ex: +261374339183"/>
                                </StackPanel>

                                <Button x:Name="SaveContactButton"
                                        Click="SaveContact_Click"
                                        Content="Enregistrer"
                                        Background="#10B981"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        CornerRadius="6"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" Margin="0,-8,0,0">
            
            <TabItem Header="Base Clients">
                <ScrollViewer Padding="4,16" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ClientVM.Clients}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:Client">
                                <Border Classes="Card" Width="280" Padding="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding NomClient}" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding PrenomClient}" FontSize="13" Foreground="#64748B"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <PathIcon Data="{StaticResource PhoneIcon}" Width="12" Height="12" Foreground="#94A3B8"/>
                                            <TextBlock Text="{Binding Telephone}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                        <Separator Margin="0,12" Background="#E2E8F0" Height="1"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="ID Système" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#F0FDF4" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding RefClient, StringFormat='C-{0}'}" FontSize="11" FontWeight="Bold" Foreground="#16A34A"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Base Fournisseurs">
                <ScrollViewer Padding="4,16" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FournisseurVM.Fournisseurs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:Fournisseur">
                                <Border Classes="Card" Width="280" Padding="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding NomFournisseur}" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding PrenomFournisseur}" FontSize="13" Foreground="#64748B"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <PathIcon Data="{StaticResource PhoneIcon}" Width="12" Height="12" Foreground="#94A3B8"/>
                                            <TextBlock Text="{Binding TelephoneFournisseur}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                        <Separator Margin="0,12" Background="#E2E8F0" Height="1"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="ID Système" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding RefFournisseur, StringFormat='REF-{0}'}" FontSize="11" FontWeight="Bold" Foreground="#3B82F6"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
            
        </TabControl>
    </Grid>
</UserControl>