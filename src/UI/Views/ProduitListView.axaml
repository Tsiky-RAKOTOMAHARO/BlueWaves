<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:coreModels="clr-namespace:Core.Models;assembly=Core"
             x:Class="UI.Views.ProduitListView"
             x:CompileBindings="False"
             Tag="Produits"
             Background="#F8FAFC">

    <Grid RowDefinitions="Auto,*" Margin="20">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Spacing="4">
                <TextBlock Text="Gestion des Produits"
                           FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Catalogue et référentiel produits"
                           FontSize="13" Foreground="#94A3B8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
                <Border Grid.Column="0" Classes="search-shell" Width="350" HorizontalAlignment="Left">
                    <TextBox x:Name="SearchProduit"
                             Text="{Binding ProduitVM.SearchQuery, Mode=TwoWay}"
                             Watermark="Rechercher un produit..."
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Background="Transparent"/>
                <Button Grid.Column="2"
                        Content="＋ Nouveau produit"
                        Classes="btn-primary btn-primary-green"
                        Click="OnNouveauProduitClick"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                <DockPanel Grid.Column="0">

                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="*,*,*"
                          Margin="0,0,0,24">
                        <Border Grid.Column="0" Classes="kpi">
                            <StackPanel>
                                <TextBlock Text="TOTAL PRODUITS" Classes="label"/>
                                <TextBlock Text="{Binding ProduitVM.Produits.Count}"
                                           FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="kpi">
                            <StackPanel>
                                <TextBlock Text="PRIX MOYEN" Classes="label"/>
                                <TextBlock Text="—"
                                           FontSize="28" FontWeight="Black" Foreground="#10B981"/>
                                <TextBlock Text="Ariary MGA" FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="kpi">
                            <StackPanel>
                                <TextBlock Text="CATÉGORIES" Classes="label"/>
                                <TextBlock Text="—"
                                           FontSize="28" FontWeight="Black" Foreground="#3B82F6"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ProduitVM.FilteredProduits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="coreModels:Produit">
                                    <Border Classes="order-card">
                                        <Grid ColumnDefinitions="4,*,*,Auto">

                                            <Border Grid.Column="0"
                                                    Background="#10B981" CornerRadius="2"/>

                                            <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NomProduit}"
                                                           FontWeight="Bold" FontSize="14" Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding CodeProduit, StringFormat='{}#{0}'}"
                                                           FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="PRIX" Classes="label"/>
                                                <TextBlock Text="{Binding Prix, StringFormat='{}{0:N0} MGA'}"
                                                           FontSize="13" Foreground="#10B981" FontWeight="Bold"/>
                                            </StackPanel>

                                            <Button Grid.Column="4" 
                                                    Content="⋮"
                                                    Width="32" Height="32"
                                                    Classes="btn-icon"
                                                    Margin="15,0,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Click="OnProduitActionsClick">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Modifier" Click="OnEditProduitClick"/>
                                                        <MenuItem Header="Supprimer" Click="OnDeleteProduitClick"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <Border Grid.Column="1"
                        x:Name="PanneauLateral"
                        IsVisible="{Binding ProduitVM.IsFormVisible}"
                        Width="380"
                        Margin="16,0,0,0"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <ScrollViewer>
                        <StackPanel Spacing="15">

                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="✕"
                                        Classes="btn-icon"
                                        Click="OnFermerFormulaireClick"/>
                                <TextBlock Text="Nouveau Produit"
                                           FontSize="18" FontWeight="Bold" Foreground="Blue"/>
                            </DockPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,5"/>

                            <TextBlock Text="INFORMATIONS GÉNÉRALES" Classes="form-section"/>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Nom du produit" Classes="label"/>
                                <TextBox Classes="form-input"
                                         Watermark="Ex: Crevettes entières"
                                         Text="{Binding ProduitVM.NomProduit, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Prix (MGA)" Classes="label"/>
                                <TextBox Classes="form-input"
                                         Watermark="Ex: 15000"
                                         Text="{Binding ProduitVM.Prix, Mode=TwoWay}"/>
                            </StackPanel>

                            <TextBlock x:Name="ProduitErrorText"
                                       Foreground="#DC2626"
                                       Text="{Binding ProduitVM.ErrorMessage}"
                                       TextWrapping="Wrap"/>

                            <Button Content="Enregistrer le produit"
                                    Classes="btn-primary btn-primary-green"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,10,0,0"
                                    Command="{Binding ProduitVM.SauvegarderCommand}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.form-section">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="Border.order-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.order-card:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style Selector="Border.kpi">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style Selector="TextBox.form-input">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-primary-green">
            <Setter Property="Background" Value="#10B981"/>
        </Style>
        <Style Selector="Button.btn-icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-icon:pointerover">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        <Style Selector="Border.search-shell">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </UserControl.Styles>

</UserControl>